{
	"name": "nebulous",
	"version": "1.0.0",
	"description": "A Discord bot made using TypeScript and Discord.JS",
	"main": "build/index.js",
	"type": "module",
	"scripts": {
		"lint": "eslint . --ext .ts",
		"lint:fix": "eslint . --ext .ts --fix",
		"format": "prettier --check .",
		"format:fix": "prettier --write .",
		"build": "tsc",
		"build:clean": "rmdir /s /q build && tsc",
		"watch": "tsc -watch",
		"start": "node build/index.js",
		"start:verbose": "node build/index.js --verbose",
		"test": "npm run lint && npm run format && npm run build",
		"precommit": "lint-staged"
	},
	"lint-staged": {
		"*.ts": [
			"eslint --fix",
			"prettier --write",
			"git add"
		]
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/TymonMarek/nebulous-client.git"
	},
	"author": "Tymon Marek",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/TymonMarek/nebulous-client/issues"
	},
	"homepage": "https://github.com/TymonMarek/nebulous-client#readme",
	"devDependencies": {
		"@typescript-eslint/eslint-plugin": "^7.8.0",
		"@typescript-eslint/parser": "^7.9.0",
		"eslint": "^8.57.0",
		"eslint-config-prettier": "^9.1.0",
		"husky": "^9.0.11",
		"lint-staged": "^15.2.2",
		"prettier": "^3.2.5"
	},
	"dependencies": {
		"chalk": "^5.3.0",
		"compressing": "^1.10.0",
		"discord.js": "^14.15.2",
		"dotenv": "^16.4.5",
		"mongoose": "^8.3.4",
		"glob": "^10.3.14",
		"typescript": "^5.4.5",
		"url": "^0.11.3"
	}
}
